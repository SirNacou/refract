CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE_NAME=refract
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=default
CLICKHOUSE_DB=${CLICKHOUSE_DATABASE_NAME}

