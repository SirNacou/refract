ADMIN_BASE_URL=localhost
DEFAULT_BASE_URL=localhost:4000

ENVIRONMENT=development
# Postgres
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=refract
DATABASE_URL="postgresql://postgres:postgres@refract-postgres:5432/refract"
# For local (non-compose) frontend usage, you may prefer:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/refract"

# API
API_URL=http://refract-api:8080
PORT=8080
REDIRECTOR_PORT=8080
JWKS_URL=http://refract-frontend:3000/api/auth/jwks

# Valkey
VALKEY_HOST=refract-valkey
VALKEY_PORT=6379
VALKEY_REDIRECT_KEY="redirect:{short_code}"
VALKEY_CLICKS_STREAM_KEY="stream:clicks"
VALKEY_READ_GROUP=clicks_stream_group
VALKEY_CONSUMER=clicks_stream_consumer_1

# Clickhouse
