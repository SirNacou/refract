FROM oven/bun:1-alpine

WORKDIR /app

# Copy config and schema files needed for migrations
COPY frontend/drizzle.config.ts ./
COPY frontend/auth-schema.ts ./
COPY frontend/drizzle ./drizzle

# Install only migration dependencies
RUN bun add drizzle-kit drizzle-orm pg dotenv

CMD ["sh", "-c", "DATABASE_URL=\"$DATABASE_URL\" bunx drizzle-kit migrate --config=./drizzle.config.ts"]

LABEL org.opencontainers.image.source=https://github.com/SirNacou/refract